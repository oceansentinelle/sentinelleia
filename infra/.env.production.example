# Ocean Sentinel V3.0 MAS - Production Environment Variables
# Copy to .env.production and configure

# Database
DATABASE_URL=postgresql://oceansentinel:${DB_PASSWORD}@timescaledb:5432/ocean_sentinel_prod

# Data Ingestion
DATA_SOURCE=erddap
STATION_ID=BARAG
INGEST_INTERVAL_SECONDS=900
INGEST_LOOKBACK_MINUTES=60

# ERDDAP Configuration
# URL template must contain {start_iso} and {end_iso} placeholders
# Example: https://ERDDAP_HOST/erddap/tabledap/DATASET.csv?time,TEMP,PSAL,PH,DOX2&time>={start_iso}&time<={end_iso}
ERDDAP_URL_TEMPLATE=https://ERDDAP_HOST/erddap/tabledap/DATASET.csv?time,TEMP,PSAL,PH,DOX2&time>={start_iso}&time<={end_iso}
ERDDAP_SOURCE_NAME=Coriolis/ERDDAP
HTTP_TIMEOUT_SECONDS=20

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
